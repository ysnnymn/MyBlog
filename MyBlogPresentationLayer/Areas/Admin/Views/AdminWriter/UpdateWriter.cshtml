@model MyBlogPresentationLayer.Areas.Admin.Models.WriterEditViewModel

@{
    ViewData["Title"] = "Yazar Güncelle";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<h2>Yazar Güncelle</h2>


<form asp-action="UpdateWriter" method="post" enctype="multipart/form-data">
    
    <!-- ID (Gizli) -->
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Ad</label>
        <input type="text" asp-for="Name" class="form-control" />
    </div>

    <div class="form-group">
        <label>Soyad</label>
        <input type="text" asp-for="Surname" class="form-control" />
    </div>

    <div class="form-group">
        <label>Kullanıcı Adı</label>
        <input type="text" asp-for="Username" class="form-control" />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input type="email" asp-for="Email" class="form-control" />
    </div>

    <div class="form-group">
        <label>Telefon</label>
        <input type="text" asp-for="PhoneNumber" class="form-control" />
    </div>

    <div class="form-group">
        <label>Şehir</label>
        <input type="text" asp-for="City" class="form-control" />
    </div>

    <div class="form-group">
        <label>Yeni Şifre</label>
        <input type="password" asp-for="Password" class="form-control" />
    </div>

    <div class="form-group">
        <label>Mevcut Resim</label><br />
        <img src="@Model.ImageUrl" width="100" />
    </div>

    <div class="form-group">
        <label>Yeni Resim</label>
        <input type="file" asp-for="Image" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-success">Güncelle</button>
</form>