@model List<AppUser>

@{
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int id = 0;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <i class="mdi mdi-book-open-page-variant mr-2" style="font-size: 28px; color:#4CAF50;"></i>
        <div>
            <h3 class="page-title mb-0">Tüm Yazarlar</h3>
            <small class="text-muted">
                Bu sayfada tüm yazarlar  listelenmektedir. Silme işlemi yalnızca admin tarafından yapılabilir.
            </small>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead class="thead-light">
            <tr>
                <th>#</th>
                <th>Ad</th>
                <th>Soyad</th>
                <th>Şehir</th>
                <th>Email</th>
                <th>Telefon No</th>
                <th>Resim</th>
                <th>Sil</th>
                <th>Güncelle</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                id++;
                <tr>
                    <td>@id</td>
                    <td>@item.Name</td>
                    <td>@item.Surname</td>
                    <td>@item.City  </td>
                    <td>@item.Email</td>
                    <td>@item.PhoneNumber</td>
                    <td>
                        <img src="@item.ImageUrl" style="width:80px;height:80px;border-radius:50%;object-fit:cover;" />
                    </td>
                    <td>
                        <form asp-area="Admin" asp-controller="AdminWriter" asp-action="DeleteWriter" asp-route-id="@item.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('Bu Yazarı silmek istediğinize emin misiniz?');">
                                Sil
                            </button>
                        </form>
                    </td>
                    <td>
                        <a asp-area="Admin"
                           asp-controller="AdminWriter"
                           asp-action="UpdateWriter"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                            Güncelle
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>