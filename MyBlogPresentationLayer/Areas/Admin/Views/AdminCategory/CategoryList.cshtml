@model List<MyBlog.EntityLayer.Concrete.Category>

@{
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int id = 0;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <i class="mdi mdi-format-list-bulleted mr-2" style="font-size:28px; color:#4CAF50;"></i>
        <div>
            <h3 class="page-title mb-0">Kategoriler</h3>
            <small class="text-muted">Bu sayfada mevcut kategoriler listelenmektedir.</small>
        </div>
    </div>
    <a asp-area="Admin" asp-controller="AdminCategory" asp-action="CreateCategory" class="btn btn-primary">
        + Yeni Kategori
    </a>
</div>

<div class="card mt-3">
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead class="thead-light">
                <tr>
                    <th>#</th>
                    <th>Kategori Adı</th>
               
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    id++;
                    <tr>
                        <td>@id</td>
                        <td>@item.CategoryName</td>
                      
                        <td>
                            <a asp-area="Admin" asp-controller="AdminCategory" asp-action="UpdateCategory" asp-route-id="@item.CategoryId" class="btn btn-warning btn-sm">
                                Düzenle
                            </a>
                            <form asp-area="Admin" asp-controller="AdminCategory" asp-action="DeleteCategory" asp-route-id="@item.CategoryId" method="post" class="d-inline">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?');">
                                    Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>