@model MyBlogPresentationLayer.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />
    <title>Login</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            overflow:hidden;

            background: linear-gradient(-45deg,#667eea,#764ba2,#6dd5ed,#23d5ab);
            background-size:400% 400%;
            animation: gradientBG 12s ease infinite;
        }

        keyframes gradientBG{
            0%{background-position:0% 50%;}
            50%{background-position:100% 50%;}
            100%{background-position:0% 50%;}
        }

        /* floating lights */

        body::before,
        body::after{
            content:"";
            position:absolute;
            width:500px;
            height:500px;
            background:rgba(255,255,255,0.1);
            filter:blur(120px);
            border-radius:50%;
            animation: float 12s infinite alternate;
        }

        body::before{
            top:-100px;
            left:-100px;
        }

        body::after{
            bottom:-100px;
            right:-100px;
            animation-delay:4s;
        }

        keyframes float{
            from{transform:translateY(0px)}
            to{transform:translateY(120px)}
        }

        .login-container{

            width:400px;
            padding:45px;

            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(20px);

            border-radius:20px;

            box-shadow:0 25px 45px rgba(0,0,0,0.25);

            color:white;

            animation:loginAppear 1s ease;

            transition:.4s;

        }

        .login-container:hover{

            transform:translateY(-5px) scale(1.02);

        }

        keyframes loginAppear{

            from{
                opacity:0;
                transform:scale(.9);
            }

            to{
                opacity:1;
                transform:scale(1);
            }

        }

        .login-container h2{
            text-align:center;
            margin-bottom:35px;
            font-weight:600;
        }

        /* INPUT */

        .input-group{
            position:relative;
            margin-bottom:25px;
        }

        .input-group i{
            position:absolute;
            top:50%;
            left:12px;
            transform:translateY(-50%);
            font-size:14px;
        }

        .input-group input{

            width:100%;
            padding:14px 14px 14px 35px;

            border:none;
            outline:none;

            background:rgba(255,255,255,0.2);

            border-radius:10px;

            color:white;
            font-size:14px;

            transition:.3s;

        }

        .input-group input:focus{

            background:rgba(255,255,255,0.35);

            box-shadow:0 0 10px rgba(255,255,255,0.4);

            transform:scale(1.02);

        }

        /* OPTIONS */

        .options{

            display:flex;
            justify-content:space-between;
            align-items:center;

            font-size:13px;
            margin-bottom:20px;

        }

        .options label{
            display:flex;
            align-items:center;
            gap:5px;
        }

        .options a{

            color:white;
            text-decoration:none;
            opacity:.8;
            transition:.3s;

        }

        .options a:hover{

            opacity:1;
            text-decoration:underline;

        }

        /* BUTTON */

        .login-btn{

            width:100%;
            padding:14px;

            border:none;

            border-radius:30px;

            background:white;

            color:#333;

            font-weight:600;

            font-size:15px;

            cursor:pointer;

            transition:.3s;

            position:relative;
            overflow:hidden;

        }

        .login-btn::before{

            content:"";
            position:absolute;
            top:0;
            left:-100%;
            width:100%;
            height:100%;

            background:linear-gradient(120deg,transparent,rgba(255,255,255,0.7),transparent);

            transition:.5s;

        }

        .login-btn:hover::before{

            left:100%;

        }

        .login-btn:hover{

            transform:translateY(-3px);

            box-shadow:0 10px 25px rgba(0,0,0,0.3);

        }

        .footer{

            text-align:center;

            margin-top:20px;

            font-size:13px;

            opacity:.8;

        }

    </style>

</head>

<body>

<div class="login-container">

    <h2>Admin Login</h2>

    <form method="post">

        <div class="input-group">
            <i class="fa fa-user"></i>
            <input asp-for="UserName" placeholder="Kullanıcı Adı" />
        </div>

        <div class="input-group">
            <i class="fa fa-lock"></i>
            <input asp-for="Password" type="password" placeholder="Şifre" />
        </div>

        <div class="options">

            <label>
                <input type="checkbox"/> Beni Hatırla
            </label>

            <a href="#">Şifremi Unuttum</a>

        </div>

        <button class="login-btn">Giriş Yap</button>

    </form>

    <div class="footer">
        MyBlog Admin Panel
    </div>

</div>

</body>
</html>